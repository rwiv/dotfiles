{
  "general": {
    "sessionRetention": {
      "enabled": true,
      "maxAge": "7d",
      "maxCount": 100,
      "minRetention": "1d"
    },
    "preferredEditor": "neovim"
  },
  "ui": {
    "theme": "Catppuccin Mocha",
    "showModelInfoInChat": false,
    "showCitations": false,
    "loadingPhrases": "off",
    "footer": {
      "showLabels": false,
      "items": ["git-branch", "model-name", "context-used"]
    },
    "customThemes": {
      "Catppuccin Mocha": {
        "name": "Catppuccin Mocha",
        "type": "custom",
        "Background": "#1e1e1e",
        "Foreground": "#cdd6f4",
        "LightBlue": "#89dceb",
        "AccentBlue": "#89b4fa",
        "AccentPurple": "#cba6f7",
        "AccentCyan": "#94e2d5",
        "AccentGreen": "#a6e3a1",
        "AccentYellow": "#f9e2af",
        "AccentRed": "#f38ba8",
        "Comment": "#9399b2",
        "Gray": "#7f849c",
        "DiffAdded": "#546d5c",
        "DiffRemoved": "#734a5f",
        "GradientColors": ["#89b4fa", "#cba6f7", "#f38ba8"]
      }
    }
  },
  "privacy": {
    "usageStatisticsEnabled": false
  },
  "model": {
    "name": "gemini-3-flash-preview",
    "compressionThreshold": 0.5
  },
  "agents": {
    "overrides": {
      "generalist": {
        "enabled": false
      },
      "codebase_investigator": {
        "enabled": false
      },
      "cli_help": {
        "enabled": false
      }
    }
  },
  "context": {
    "fileFiltering": {
      "respectGitIgnore": true,
      "respectGeminiIgnore": true
    }
  },
  "tools": {
    "useRipgrep": true,
    "truncateToolOutputThreshold": 40000
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "experimental": {
    "enableAgents": true
  }
}
